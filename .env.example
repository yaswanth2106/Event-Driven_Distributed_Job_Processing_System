# Database configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platform_db

# LRU cache instances
CACHE_HOST=127.0.0.1
AUTH_CACHE_PORT=6379
WORKER_CACHE_PORT=6380
TASK_CACHE_PORT=6381

# Internal Event Bus Broker
EVENT_BROKER_HOST=127.0.0.1
EVENT_BROKER_PORT=9500

# Coordinator
COORDINATOR_HOST=127.0.0.1
COORDINATOR_PORT=9000

# API Gateway Auth & Networking
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
GATEWAY_AUTH_TOKEN=secret-token-key

# Gateway boundaries
MAX_HEADER_SIZE=8192
MAX_CONTENT_LENGTH=1048576
REQUEST_TIMEOUT=5.0

# Circuit Breakers
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_TIMEOUT=5.0

# Dashboards & UI
WEBSOCKET_DASHBOARD_PORT=8080
FRONTEND_PORT=8081
